Include ~/.ssh/config.local

Host *
  Protocol 2

  # Network stability/optimization
  # ExitOnForwardFailure yes
  ServerAliveInterval 15
  ServerAliveCountMax 3
  TCPKeepAlive yes
  ConnectTimeout 5
  ConnectionAttempts 2
  # StreamLocalBindUnlink yes

  # Multiplexing
  ControlMaster auto
  ControlPath ~/.ssh/tmp/master-%C
  ControlPersist 15h

  # Quality of Life
  CheckHostIP no
  VisualHostKey no
  # HashKnownHosts yes
  SendEnv -LC_* -LANG*
